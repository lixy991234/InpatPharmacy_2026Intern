                        break;
                    }
                    case 'ChineseName': {
                        content = `${detail.ChineseName}`;
                        break;
                    }
                    case 'ItemName': {
                        content = `${detail.ItemName}`;
                        break;
                    }
                    case 'ItemCode': {
                        content = `${detail.ItemCode}`;
                        break;
                    }
                    case 'GenericName': {
                        content = `${detail.GenericName}`;
                        break;
                    }
                    case 'IndicationsA1': {
                        content = `${detail.IndicationsA1}`;
                        break;
                    }
                    case 'IndicationsA2': {
                        content = `${detail.IndicationsA2}`;
                        break;
                    }
                    case 'AdultDosing': {
                        content = `${detail.AdultDosing}`;
                        break;
                    }
                    case 'AdverseEffectsA1': {
                        content = `${detail.AdverseEffectsA1}`;
                        break;
                    }
                    case 'AdverseEffectsA2': {
                        content = `${detail.AdverseEffectsA2}`;
                        break;
                    }
                    case 'Contraindication': {
                        content = `${detail.Contraindication}`;
                        break;
                    }
                    case 'Precautions': {
                        content = `${detail.Precautions}`;
                        break;
                    }
                    case 'NhiNorm': {
                        content = `${detail.NhiNorm}`;
                        break;
                    }
                    case 'Dispose': {
                        content = `${detail.Dispose}`;
                        break;
                    }
                    case 'Storage': {
                        content = `${detail.Storage}`;
                        break;
                    }
                    case 'HighAlert': {
                        switch (detail.HighAlert) {
                            case 0:
                                content = "非高警訊藥品";
                                break;
                            case 1:
                                content = "高警訊藥品";
                                break;
                            case 2:
                                content = "化療注射劑";
                                break;
                            case 3:
                                content = "兒童專用藥";
                                break;
                            case 4:
                                content = "人體臨床試驗藥品";
                                break;
                            default:
                                break;
                        }
                        break;
                    }
                    case 'Pregnancy': {
                        content = `${detail.Pregnancy}級`;
                        break;
                    }
                    case 'Injection': {
                        content = `${detail.Injection}`;
                        break;
                    }
                    case 'ExpireHourDesc': {
                        if (detail.ExpireHour == 0) { content = "不限"; }
                        else { content = `${detail.ExpireHour} 小時`; }
                        break;
                    }
                    case 'DrugImg': {
                        content = `${detail.DrugImg}`;
                        break;
                    }
                    case 'DrugPkgImg': {
                        content = `${detail.DrugPkgImg}`;
                        break;
                    }
                    default:
                        break;
                }
                $(this).html(content);
                $("#DrugImg").attr("src", `${detail.DrugImg}`);
                $("#DrugPkgImg").attr("src", `${detail.DrugPkgImg}`);
            })
        }


        function ShowDrugBatchInfo(batch) {
            //console.log(batch);
            $("#batchlist").remove();
            var list = JSON.parse(batch);
            var htmlStr = `<table id="batchlist">
                            <tr>
                              <td class="batch_title" colspan="4"><p style="color: black; font-size:3rem; font-weight:900">${list.ItemName}</p></td>
                            </tr>`
            for (let i = 0; i < list.detail.length; i++) {
                htmlStr += `<tr>
                                <td class="batch_title"><p style="color: black;">批號:</p></td>
                                <td class="batch_item"><p>${list.detail[i].BatchNo}</p></td>
                                <td class="batch_title"><p style="color: black">用量:</p></td>
                                <td class="batch_item"><p>${list.detail[i].用量}</p></td>
                            </tr>`
            }

            htmlStr += "</table>";
            $(".batch_detail").append(htmlStr);
    }


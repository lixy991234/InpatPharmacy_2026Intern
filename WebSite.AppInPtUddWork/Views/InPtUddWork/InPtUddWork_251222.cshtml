@model WebSite.AppInPtUddWork.ViewModels.UddWorkViewModel

@{
    ViewBag.Title = "InPtUddWork";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>檢藥</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @using WebSite.AppInPtUddWork.Helpers
    <!-- CSS only -->
    <link rel="stylesheet" href="https://MDevWS.csh.org.tw/Components/bootstrap/5.2.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://MDevWS.csh.org.tw/Components/FontAwesome/6.1.2/css/all.css" />
    <link href="../Content/style/inptuddwork-style.css" rel="stylesheet">
</head>
<body>
    <form id="go" method="get">
        <input type="hidden" name="ward" id="ward" value="@Model.headler.ward" />
        <input type="hidden" name="roomBed" id="roomBed" value="" />
    </form>
    <div class="pad">
        <header>
            <!-- Header -->
            <div class="header_div">
                <img src="~/images/back.png" class="back_img" style="position: absolute;left: 10px; top: 12px; " />
                <p class="header_title">@Model.headler.title</p>
                <div style=" position: absolute; width: 125px; display: flex; right: 0; top: 8px;">
                    <div style=" width: 70px; border: 1px solid white; display: flex; border-radius: 5px; height: 36px;" class="change_line_block">
                        <div class="border_box"></div>
                        <svg aria-hidden="true" focusable="false" data-prefix="fas" data-icon="list-ul" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="svg-inline--fa fa-list-ul fa-lg line_btn"><path fill="currentColor" d="M16 96C16 69.49 37.49 48 64 48C90.51 48 112 69.49 112 96C112 122.5 90.51 144 64 144C37.49 144 16 122.5 16 96zM480 64C497.7 64 512 78.33 512 96C512 113.7 497.7 128 480 128H192C174.3 128 160 113.7 160 96C160 78.33 174.3 64 192 64H480zM480 224C497.7 224 512 238.3 512 256C512 273.7 497.7 288 480 288H192C174.3 288 160 273.7 160 256C160 238.3 174.3 224 192 224H480zM480 384C497.7 384 512 398.3 512 416C512 433.7 497.7 448 480 448H192C174.3 448 160 433.7 160 416C160 398.3 174.3 384 192 384H480zM16 416C16 389.5 37.49 368 64 368C90.51 368 112 389.5 112 416C112 442.5 90.51 464 64 464C37.49 464 16 442.5 16 416zM112 256C112 282.5 90.51 304 64 304C37.49 304 16 282.5 16 256C16 229.5 37.49 208 64 208C90.51 208 112 229.5 112 256z" class=""></path></svg>
                        <svg aria-hidden="true" focusable="false" data-prefix="fas" data-icon="grid-2" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="svg-inline--fa fa-grid-2 fa-lg block_btn"><path fill="currentColor" d="M192 176C192 202.5 170.5 224 144 224H48C21.49 224 0 202.5 0 176V80C0 53.49 21.49 32 48 32H144C170.5 32 192 53.49 192 80V176zM192 432C192 458.5 170.5 480 144 480H48C21.49 480 0 458.5 0 432V336C0 309.5 21.49 288 48 288H144C170.5 288 192 309.5 192 336V432zM256 80C256 53.49 277.5 32 304 32H400C426.5 32 448 53.49 448 80V176C448 202.5 426.5 224 400 224H304C277.5 224 256 202.5 256 176V80zM448 432C448 458.5 426.5 480 400 480H304C277.5 480 256 458.5 256 432V336C256 309.5 277.5 288 304 288H400C426.5 288 448 309.5 448 336V432z" class=""></path></svg>
                    </div>
                    <div id="dropdownMenuButton1" style="float: right; width: 35px; height: 35px; margin-left: 10px; margin-top: -3px; font-size: 30px; color: white;">
                        <i class="fa-solid fa-ellipsis-vertical"></i>
                    </div>
                    <div class="dropdown" style="right: 0rem; top: 0rem">
                        <!--style="right: 20rem; top: -2rem"-->
                        <ul class="dropdown-menu dropdown-menu_1" style="width: 200px; font-size: 18px; font-weight: 500;">
                            <li><a class="dropdown-item" href="#">回首頁</a></li>
                            <li><a class="dropdown-item" href="SelectNursingStation">護理站</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <div>

                <div class="patient_info_main" style="display: flex">
                    <!-- Patient Info -->
                    <div style="width: 85%">
                        <div class="patient_info_main_div">
                            <p>患者:@Model.headler.chartNo&nbsp;&nbsp;@Model.headler.ptName&nbsp;(@Model.headler.sex)&nbsp;@Model.headler.birthday (@Model.headler.age)&nbsp;&nbsp;體重:@Model.headler.weight</p>
                        </div>
                        <div class="patient_info_sec">
                            <p style="display: inline-block;">床號&nbsp;:&nbsp; @Model.headler.roombed &nbsp;科別&nbsp;:&nbsp; @Model.headler.division &nbsp;主治醫師&nbsp;:&nbsp; @Model.headler.doctor &nbsp;</p>
                        </div>
                        <div class="patient_info_sec">
                            <p style="display: inline-block;">@Model.headler.cycleTime &nbsp;</p>
                        </div>
                    </div>
                    <div class="patient_info_main_div" style="display: flex; align-items:center">
                        <div class="patient_info_sec" style="float: right; position: relative">
                            <div>
                                <div style=" display: flex; flex-direction:column">
                                    @{
                                        if (Model.prnOrderList.Count != 0)
                                        {
                                            <div class="header_div_button prn_btn" style="background-color: #1b8ba9; color: white; margin-bottom: 1rem">
                                                <p>PRN</p>
                                            </div>
                                        }
                                    }
                                    <div class="header_div_button 33block_btn" style=" background-color: #2362ab; color: white; ">
                                        <p>檢驗報告</p>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div style="position: absolute; top: 70px; right: 0px; z-index: 1000;  ">
                                    @{
                                        if (Model.prnOrderList.Count != 0)
                                        {
                                            <div class="prn">
                                                <div class="block_header">
                                                    <p>PRN</p>
                                                </div>
                                                <div class="block_content" style="height: 220px; overflow: scroll; width: 100%">
                                                    @foreach (var PRN in Model.prnOrderList)
                                                    {
                                                        <div class="PRN_div">
                                                            <p>@PRN.ItemName</p>
                                                            <p style=" font-size: 16px; color: rgb(255 255 255 / 65%); ">@PRN.GenericName</p>
                                                            <div class="PRN_div_sub">
                                                                <p style="color: rgb(255 255 255 / 50%);">劑量:</p> <p>@PRN.Dose</p>
                                                                <p style="color: rgb(255 255 255 / 50%);">頻率:</p> <p>@SiteHelper.DrugUsage(PRN.UsageNo)</p>
                                                                <p style="color: rgb(255 255 255 / 50%);">途徑:</p> <p>@SiteHelper.DrugWay(PRN.WayNo)</p>
                                                                <p style="color: rgb(255 255 255 / 50%);">總量:</p> <p>@PRN.Qty</p>
                                                                <p style="color: rgb(255 255 255 / 50%);">單位:</p> <p>@PRN.DoseUnit</p>
                                                            </div>
                                                        </div>
                                                        <hr />
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                    <div class="_33block">
                                        <div class="block_header">
                                            <p>檢驗報告</p>
                                        </div>
                                        <div class="block_content">
                                            <table>
                                                <tr>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">ALT</p></td>
                                                    <td><p>@Model.labReport.ALT</p></td>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">AST</p></td>
                                                    <td><p>@Model.labReport.AST</p></td>
                                                    <td colspan="2"></td>
                                                </tr>
                                                <tr>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">CRE</p></td>
                                                    <td><p>@Model.labReport.CRE</p></td>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">CrCl</p></td>
                                                    <td><p>@Model.labReport.CrCl</p></td>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">IBW</p></td>
                                                    <td><p>@Model.labReport.IBW</p></td>
                                                </tr>
                                                <tr>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">eGFR</p></td>
                                                    <td><p>@Model.labReport.eGFR</p></td>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">CONC</p></td>
                                                    <td><p>@Model.labReport.Blood</p></td>
                                                    <td><p style="color: rgb(255 255 255 / 50%);">BSA</p></td>
                                                    <td><p>@Model.labReport.BSA</p></td>
                                                </tr>
                                                <tr>
                                                    <td rowspan="10"><p style="color: rgb(255 255 255 / 50%);">ADR</p></td>
                                                </tr>
                                                @foreach (var item in Model.labReport.ADR)
                                                {
                                                    <tr>
                                                        <td colspan="5"><p>@item.ItemNameDesc</p></td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="patient_info_sec_open expand">
                    <p class="p_in_sec_open">主診斷&nbsp;:&nbsp; @Model.headler.chtName</p>
                    <p class="p_in_sec_open" style="color: #b70202;">
                        @{ if (Model.headler.allergy != "") { Write("藥物過敏 : " + Model.headler.allergy); } }
                    </p>
                    <p class="p_in_sec_open">
                        @{ if (Model.headler.labReport != "") { Write("檢查報告 : " + Model.headler.labReport); } }
                    </p>
                    <p class="p_in_sec_open">
                        @{ if (Model.headler.doseModification != "") { Write("劑量調整 : " + Model.headler.doseModification); }}
                    </p>
                    <div class="p_in_sec_open">
                        @{
                            var n = Model.interList.Count;
                            int i = 0;
                            foreach (var interatction in Model.interList)
                            {
                                if (interatction.Significance != 0)
                                {
                                    if (i == 0)
                                    {
                                        <p style="display:inline">交互作用&nbsp;:&nbsp;</p>
                                    }
                                    else
                                    {
                                        <br />
                                    }
                                    i++;
                                    <p class="p_interatction interatction_@i" value="@i" style="display:inline">
                                        @interatction.ItemCode1-@interatction.ItemName1 , @interatction.ItemCode2-@interatction.ItemName2 &nbsp; [&nbsp;級數&nbsp;:&nbsp; @interatction.Significance &nbsp;]
                                    </p>
                                    <div class="interatction_hidden interatction_detail_@i">
                                        <p>[&nbsp;機轉&nbsp;:&nbsp; @interatction.Mechanism &nbsp;]</p>
                                        <p>[&nbsp;管理&nbsp;:&nbsp; @interatction.Management &nbsp;]</p>
                                    </div>
                                }
                            }
                        }
                    </div>
                </div>
                <div class="img_center_div"><img src="~/images/dropdown.png" class="img_open img_expand"></div>
            </div>
        </header>
        <main>
            <div class="body_content">
                @{int white_count = 0; string bgcolor; int med_n = -1; bool isChecked;}
                <!-- Line Style -->
                <form id="checked" method="post">
                    <input type="hidden" id="expandDate" name="expandDate" value="@Model.headler.expandDate" />
                    <input type="hidden" id="visitNo" name="visitNo" value="@Model.headler.visitNo" />
                    <div class="white_space" style="margin-bottom:5px;"></div>
                    <div class="row line_style" style="margin: 0; padding: 0;">
                        @foreach (var item in Model.dataDetailsList)
                        {
                            med_n++;
                            white_count++;
                            bgcolor = "#ddd";

                            if (@item.IsSelf == "Y")
                            {
                                bgcolor = "#ffffa2";
                            }
                            else
                            {
                                bgcolor = "unset";
                            }
                            string seqNoNum = string.Format("seqNo{0}", med_n + 1);

                            <div class="body_straight col-12" style="margin: 2px 0; padding: 0; width: 100%; position: relative; overflow-x: hidden;">
                                <div class="swipe_box" style="width: calc(100% + 1000px); display: flex; position: relative; ">
                                    <div style="width:500px;display:inline;visibility:hidden;"></div>
                                    <div class="med_content_outside @{ if (@item.IsChecked) { Write("green_border"); } }">
                                        <input type="hidden" id="seqNo" name="seqNo" value="@item.SeqNo.ToString()">
                                        <input type="hidden" id="isChecked" name="isChecked" value="@item.IsChecked.ToString()" />
                                        @*<div id="seqNo" value="@item.SeqNo.ToString()"></div>*@
                                        @*<div id="isChecked" value="@item.IsChecked.ToString()"></div>*@
                                        <div class="med_@med_n med_content" value="med_@med_n">
                                            <div class="mark_content">
                                                <div class="mark_content_bottom row" style="display:flex; justify-content: space-evenly">
                                                    @{var hid = "";}
                                                    @if (item.CtrlDrug == "N")
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items" style="background-color: #ef3c3c; color: #fff35d;@hid"><p style="margin-top: 4px;">管</p></div>
                                                    @{hid = "";}
                                                    @if (item.HighAlert != 1)
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items" style="background-color: #ffd522; color: #b51900;@hid"><p style="margin-top: 4px;">警</p></div>
                                                    @{hid = "";}
                                                    @if (item.IsFreezer == false)
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items" style="background-color: #2a97f7; color: white;@hid"><p style="margin-top: 4px;">冰</p></div>
                                                    @{hid = "";}
                                                    @if (item.IsDC == false)
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items" style="background-color: #eb3ff1; color: white;@hid"><p style="margin-top: 4px;">DC</p></div>
                                                    @{hid = "";}
                                                    @if (item.IsExpensive == false)
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items" style="background-color: #313232; color: white;@hid"><p style="margin-top: 4px;">貴</p></div>
                                                    @{hid = "";}
                                                    @if (item.Remark == "")
                                                    {
                                                        hid = "visibility:hidden;";
                                                    }
                                                    <div class="col-4 mark_items remark remark_btn" style="border-radius: 28px; background-color: #ddd; color: green;@hid "><p style="margin-top: 11px; font-size: 12px;">備註</p></div>
                                                </div>
                                            </div>
                                            <div class="med_content_right" style="background-color: @bgcolor">
                                                <div class="med_content_inside">
                                                    <div>
                                                        <p class="med_name">@item.ItemName </p>
                                                        <p class="generic_name">@item.GenericName</p>
                                                    </div>
                                                    <div class="left_bottom">
                                                        <div class="med_detail">
                                                            <div class="row_div">
                                                                <div class="col-4_div detail" style="display: flex; align-items:flex-end;">
                                                                    <p>劑量&nbsp;:&nbsp;</p> <p class="items">@item.Dose</p>
                                                                    <p>頻率&nbsp;:&nbsp;</p> <p class="items"> @item.Usage</p>
                                                                    <p>途徑&nbsp;:&nbsp;</p> <p class="items"> @item.Way</p>
                                                                    @{
                                                                        if (item.BatchList.detail.Count == 0)
                                                                        {
                                                                            <p style="color: #d1403d">總量&nbsp;:&nbsp;</p><p class="items" style="color: #d1403d">@item.TotQty</p>
                                                                        }
                                                                        else
                                                                        {
                                                                            var batchStr = new JavaScriptSerializer().Serialize(item.BatchList);
                                                                            <p class="batch_show" style="color: #d1403d; text-decoration: underline;" value="@batchStr">總量&nbsp;:&nbsp;</p>
                                                                            <p class="items batch_show" style="color: #d1403d; text-decoration: underline; margin-bottom: -2px;" value="@batchStr">@item.TotQty</p>
                                                                        }
                                                                    }
                                                                    <p>單位&nbsp;:&nbsp;</p> <p class="items"> @item.DoseUnit</p>
                                                                    <p>磨粉&nbsp;:&nbsp;</p> <p class="items"> @item.IsMill</p>
                                                                </div>

                                                            </div>
                                                            <div class="med_time"><p>開始時間&nbsp;:&nbsp; @item.StartTime&nbsp;&nbsp;&nbsp;&nbsp;</p><p>結束時間&nbsp;:&nbsp; @item.EndTime</p></div>
                                                            <div></div>
                                                        </div>
                                                        <!---->
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="img">
                                                @using System.Web.Script.Serialization
                                                @{
                                                    var imageUrl = String.Format("http://www.csh.org.tw/into/pharm/Drugimages/{0}.jpg", item.ItemCode);
                                                    var itemStr = new JavaScriptSerializer().Serialize(Model.dataDetailsList[med_n]);
                                                }
                                                <div class="medImg_div">
                                                    <i class="fa-solid fa-circle-check check_svg jq_med_img" style=" @{ if (@item.IsChecked) { Write("display: block"); }} "></i>
                                                    <i class="fa-regular fa-circle-check check_svg jq_med_img" style="@{ if (@item.IsChecked) { Write("display: block;"); }} color: #66cf01"></i>
                                                    <img src="@String.Format("http://www.csh.org.tw/into/pharm/Drugimages/{0}.jpg", item.ItemCode)" class="jq_med_img med_img" value="@itemStr">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="remark_content">
                                            <div style="width:calc(100% - 7px);border:1px solid black;border-radius:5px;padding:5px;">
                                                <p>備註&nbsp;:&nbsp;@item.Remark</p>
                                            </div>
                                        </div>
                                        <div class="remark_white">
                                            <div style="width: calc(100% - 7px); border: 1px solid black; border-radius: 5px; padding: 5px;">
                                                <p>備註&nbsp;:&nbsp;@item.Remark</p>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="width: 500px; visibility: hidden;"></div>
                                </div>
                            </div>

                        }
                    </div>
                </form>

                <!-- block Style-->
                @{white_count = 0; bgcolor = string.Empty; med_n = -1;isChecked = false;}
                <form id="checked" method="post">
                    <input type="hidden" id="expandDate" name="expandDate" value="@Model.headler.expandDate" />
                    <input type="hidden" id="visitNo" name="visitNo" value="@Model.headler.visitNo" />
                    <div class="row block_style" style="margin:0;padding:0;">
                        @foreach (var item in Model.dataDetailsList)
                        {
                            med_n++;
                            white_count++;
                            bgcolor = "#ddd";

                            if (@item.IsSelf == "Y")
                            {
                                bgcolor = "#ffffa2";
                            }
                            else
                            {
                                bgcolor = "unset";
                            }

                            <div class="body_block col-6" style="margin: 2px 0; padding: 0;position: relative; overflow-x: hidden; width:49%">
                                <div class="swipe_box" style="width: calc(100% + 1000px); display: flex; position: relative; ">
                                    <div style="width:495px;display:inline;visibility:hidden;margin-right:10px;"></div>
                                    <div class="med_@med_n med_content_block @{ if (@item.IsChecked) { Write("green_border"); } } ">
                                        <input type="hidden" id="seqNo" name="seqNo" value="@item.SeqNo.ToString()">
                                        <input type="hidden" id="isChecked" name="isChecked" value="@item.IsChecked.ToString()" />

                                        <div class="med_content_right_block">
                                            <div class="med_content_inside_block" style="background-color: @bgcolor">
                                                <div style="padding: 0 5px;padding-top:3px;">
                                                    <p class="med_name">@item.ItemName </p>
                                                    <p class="generic_name">學名&nbsp;:&nbsp; @item.GenericName</p>
                                                </div>
                                                <div class="left_bottom">
                                                    <div class="med_detail">
                                                        <div class="row_div" style="padding: 0 5px;">
                                                            <div class="col-4_div detail">
                                                                <p>劑量&nbsp;:&nbsp;</p> <p class="items">@item.Dose</p>
                                                                <p class="items"> @item.Usage</p>
                                                                <p class="items"> @item.Way</p>
                                                                <p style="color: #d1403d">總量&nbsp;:&nbsp;</p> <p class="items" style="color: #d1403d"> @item.TotQty</p>
